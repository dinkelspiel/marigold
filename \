package main

import "core:fmt"

Parser :: struct {
	current_token: ^Token
}

ParserErrorKind :: enum {
	None,
	AdvanceFailed,
	UnexpectedToken
}

ParserError :: struct {
	kind: ParserErrorKind,
	message: string
}

error :: proc(kind: ParserErrorKind, message: string = "") -> ParserError {
	return { kind, message };
}

AstFunctionCall :: struct {
	identifier: string,
	arguments: []AstValue
}

AstCodeBlock :: struct {
	nodes: []AstNode
}

AstFunctionDeclaration :: struct {
	identifier: string,
	code_block: AstCodeBlock
}

AstValue :: union {
	string
}

AstNode :: union {
	AstFunctionCall	
}

parse_root :: proc(parser: ^Parser) -> (err: ParserError) {
	token, ok := advance(parser)	
	if !ok do return error(.AdvanceFailed) 
	if token.kind != .Identifier do return error(.UnexpectedToken, fmt.tprintf("expected identifier in root, found: %v", token.kind))

	followup: ^Token
	followup, ok = advance(parser)
	if !ok do return error(.AdvanceFailed)
	if followup.kind != .TypeDec do return error(.UnexpectedToken, fmt.tprintf("expected :: after identifier in root found: %v", followup.kind))

	if parser.current_token.kind == .ParenOpen {
		parse_function(parser)
	}

	return error(.None)
}

parse_function :: proc(parser: ^Parser) -> (err: ParserError) {
	if parser.current_token.kind != .ParenOpen {
		return error(.UnexpectedToken, fmt.tprintf("expected ( at start of function arguments, found: %v", parser.current_token))
	}

	_, err = advance_assert(parser, .ParenOpen)
	if err.kind != .None do return err

	_, err = advance_assert(parser, .ParenClose)	
	if err.kind != .None do return err

	return error(.None)
}

parse_block :: proc(parser: ^Parser, nodes: [dynamic]AstNode) -> (node: Maybe(AstFunctionDeclaration), err: ParserError) {
	_, err = advance_assert(parser, .BracketOpen)
	if err.kind != .None do return nil, err

	#partial switch parser.current_token.kind {
		case .Identifier:
			if parser.current_token.next.kind == .ParenOpen {
				func_call, func_err := parse_function_call(parser)	
				if func_err.kind != nil do return nil, func_err

				return parse_block(parser, append(nodes, AstNode(func_call))) 
			} else do return nil, error(.UnexpectedToken, fmt.tprintf("expected ( for function call, found %v", parser.current_token.next.kind)) 
	
		case .BracketClose:
			node = AstFunctionDeclaration { identifier = parser.current_token.value.(string), code_block = { nodes[:] } }
			advance(parser)
			return 
		case: return nil, error(.UnexpectedToken, fmt.tprintf("expected identifier in block root, found %v", parser.current_token.next.kind))
	}

	return parse_block(parser, nodes) 
}

parse_function_call :: proc(parser: ^Parser) -> (node: Maybe(AstFunctionCall), err: ParserError) {
	identifier: ^Token
	identifier, err = advance_assert(parser, .Identifier)
	if err.kind != .None do return nil, err

	_, err = advance_assert(parser, .ParenOpen)
	if err.kind != .None do return nil, err

	value: ^Token
	value, err = advance_assert(parser, .String)
	if err.kind != .None do return nil, err

	value_node: AstValue = value.value.(string)
	
	_, err = advance_assert(parser, .ParenClose)
	if err.kind != .None do return nil, err

	node = AstFunctionCall { identifier = identifier.value.(string), arguments = { value_node } }       
	return node, error(.None)	
}

advance :: proc(parser: ^Parser) -> (token: ^Token, ok: bool) {
	token = parser.current_token
	if parser.current_token.next == nil do return nil, false
	parser.current_token = parser.current_token.next
	return token, true
}

advance_assert :: proc(parser: ^Parser, assert_token: TokenKind) -> (token: ^Token, err: ParserError) {
	advance_ok: bool
	token, advance_ok = advance(parser)
	if !advance_ok do return nil, error(.AdvanceFailed)
	if token.kind != assert_token {
		return nil, error(.UnexpectedToken, fmt.tprintf("expected '%v' at end of function arguments, found %v", assert_token, token.kind))
	}
	return token, error(.None)
}
